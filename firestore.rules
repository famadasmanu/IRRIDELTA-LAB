rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Básicos de sesión
    function isAuthenticated() { return request.auth != null; }
    function isAnonymous() { return request.auth.token.firebase.sign_in_provider == 'anonymous'; }

    // Validación de roles de forma SEGURA consultando directamente a la BD
    function getRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc == null ? 'ninguno' : userDoc.data.role;
    }

    // Clasificación Rápida de Roles
    function isAdmin() { return getRole() == 'admin'; }
    function isTecnico() { return getRole() == 'tecnico' || isAdmin(); }
    function isVendedor() { return getRole() == 'vendedor' || isAdmin(); }
    function isOperario() { return getRole() == 'operario' || isTecnico() || isVendedor(); }

    function isGuestBypass() { return isAnonymous(); }

    // -------- REGLAS ESPECÍFICAS DE COLECCIONES -------- //
    
    // 0. Configuración global (Logo y metadata pública)
    match /public_config/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }

    // 1. Colección de Seguridad (Roles)
    match /users/{userId} {
      // El Invitado ya NO puede leer la colección de roles.
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (isAdmin() || request.auth.uid == userId);
      allow delete: if isAuthenticated() && isAdmin();
    }

    // 2. Colecciones de Alta Sensibilidad (Gerencia, RRHH, Finanzas)
    // El Invitado y los operarios básicos NO tienen permiso de lectura ni escritura aquí.
    match /personalData/{document=**} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin() && !isAnonymous();
    }
    match /personal_vehicles/{document=**} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin() && !isAnonymous();
    }
    match /personal_deliveries/{document=**} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin() && !isAnonymous();
    }
    match /corrective_issues/{document=**} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin() && !isAnonymous();
    }
    match /upcoming_services/{document=**} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin() && !isAnonymous();
    }
    match /rentabilidad/{document=**} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin() && !isAnonymous();
    }
    match /cheques/{document=**} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin() && !isAnonymous();
    }
    match /pagos/{document=**} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin() && !isAnonymous();
    }
    match /proveedores/{document=**} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin() && !isAnonymous();
    }

    // 3. Colecciones Operativas y de Exposición (Trabajos, Clientes, Inventario)
    // El Modo Invitado SÍ tiene acceso de lectura para que pueda ver la demostración funcional.
    match /clientes/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && !isAnonymous() && (isTecnico() || isVendedor());
    }
    match /clientes_data/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && !isAnonymous() && (isTecnico() || isVendedor());
    }
    match /archivos/{document=**} {
      allow read: if isAuthenticated() && (isVendedor() || isGuestBypass());
      allow write: if isAuthenticated() && !isAnonymous() && isVendedor();
    }
    match /trabajos_portfolio/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && !isAnonymous() && isOperario();
    }
    match /trabajos_anotaciones/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && !isAnonymous() && isOperario();
    }
    match /projects/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && !isAnonymous() && isOperario();
    }
    match /inventario_maquinas/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && !isAnonymous() && isOperario();
    }
    match /inventario_aditivos/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && !isAnonymous() && isOperario();
    }
    match /inventario_generales/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && !isAnonymous() && isOperario();
    }
    match /alertas/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && !isAnonymous() && isOperario();
    }
    match /partner_news/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin() && !isAnonymous();
    }
    match /directorio_profesionales/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin() && !isAnonymous();
    }

    // 4. Fallback Global BLINDADO (Si nos olvidamos de declarar una colección)
    match /garantias_y_maquinas/{document=**} {
      // El cliente desde la web puede crear el documento. Nadie (ni invitado) puede leerlo salvo admin/tecnico.
      allow create: if true;
      allow read, update, delete: if isAuthenticated() && (isAdmin() || isTecnico());
    }

    match /{collection}/{document=**} {
      // PROHIBICIÓN de lectura genérica abierta. 
      // Solo el Admin puede leer si algo quedó sin configurar. Evita robos masivos de datos.
      allow read: if isAuthenticated() && isAdmin();
      
      // Prohibición de escritura genérica para anónimos.
      allow write: if isAuthenticated() && !isAnonymous() && isOperario();
    }
  }
}
